modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = [
  "ca-certificates",
  "fontconfig",
  "freetype",
  "liberation_ttf",
  "wget",
  "xdg-utils",
  "xvfb",
  "alsa-lib",
  "atk",
  "at-spi2-atk",
  "cairo",
  "cups",
  "dbus",
  "expat",
  "gdk-pixbuf",
  "glib",
  "gtk3",
  "nspr",
  "nss",
  "pango",
  "mesa",
  "libgbm",
  "gcc.cc.lib",
  "stdenv.cc.cc.lib",
  "xorg.libX11",
  "xorg.libX11.dev",
  "xorg.libXcomposite",
  "xorg.libXcursor",
  "xorg.libXdamage",
  "xorg.libXext",
  "xorg.libXfixes",
  "xorg.libXi",
  "xorg.libXrandr",
  "xorg.libXrender",
  "xorg.libXScrnSaver",
  "xorg.libXtst",
  "xorg.libxcb"
]

[userenv]

[userenv.shared]
PORT = "3000"
WEB_ORIGIN = "https://${REPLIT_DEV_DOMAIN}"
JWT_SECRET = "dev-jwt-secret-change-in-production"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/web && pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/api && pnpm dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 5173

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production node apps/api/dist/main.js"]
build = ["bash", "-c", "pnpm install && pnpm --filter @invoxa/api prisma:generate && pnpm --filter @invoxa/api build && pnpm --filter @invoxa/web build"]
